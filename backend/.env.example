# Spring backend configuration — copy to .env or export before running.
# Values come from Supabase Dashboard -> Project Settings.

# --- Database (Project Settings -> Database -> Connection string, JDBC) ---
SUPABASE_DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=<your-db-password>

# --- Auth Admin API (Project Settings -> API) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# --- Optional tuning ---
PORT=8080
POLLER_FIXED_DELAY_MS=90000
POLLER_ENABLED=true
CORS_ALLOWED_ORIGINS=*
